# Exodia secrets — copy to .env and fill in. .env is git-ignored and is loaded
# automatically (see config.load_dotenv); an already-exported variable wins.

# --- Idea generation (AI-Scientist-v2) ---------------------------------------
# Pick ONE provider's key to match `ideation.model` in config.yaml.
GEMINI_API_KEY=                 # for gemini-* model ids (default config)
# OPENAI_API_KEY=               # for gpt-* / o1 / o3 model ids
# ANTHROPIC_API_KEY=            # for claude-* model ids
# Path to a local clone of https://github.com/SakanaAI/AI-Scientist-v2
EXODIA_AISCIENTIST_DIR=

# --- Voting / feedback backend (GitHub Issues) -------------------------------
# A token with `issues: write` to create/refresh idea issues and read tallies.
# In GitHub Actions the built-in GITHUB_TOKEN is used automatically.
GITHUB_TOKEN=
# owner/repo hosting the idea issues (overrides config.yaml site.repo / $GITHUB_REPOSITORY)
# GITHUB_REPOSITORY=ju2ez/exodia
